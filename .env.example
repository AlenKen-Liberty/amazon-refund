# Quick smoke test:
#   Fill the LLM settings below and run `ar test-llm`.
# Full workflow:
#   Also fill the DB settings and connect a logged-in Chrome session over CDP.

# Chrome / CDP
AR_CDP_PORT=9222

# Database store (required for collect/check/analyze/refund)
# Built-in backend today: oracle
AR_DB_BACKEND=oracle

# Oracle backend settings
AR_DB_USER=
AR_DB_PASSWORD=
AR_DB_DSN=
AR_DB_WALLET_DIR=
AR_DB_WALLET_PASSWORD=

# LLM chat endpoint (used by the refund agent and `ar test-llm`)
AR_LLM_PROVIDER=openai_compatible
AR_LLM_BASE_URL=http://127.0.0.1:7860
AR_LLM_MODEL=codex

# Optional alternate provider settings for the price-extraction LLM fallback
AR_OLLAMA_URL=http://localhost:11434
AR_OLLAMA_MODEL=qwen3:8b
AR_ANTHROPIC_API_KEY=
AR_OPENAI_API_KEY=

# Refund rules
AR_MIN_REFUND_AMOUNT=2.0
AR_MIN_REFUND_PCT=5.0
AR_AMAZON_ONLY=true
AR_MAX_DAILY_REFUNDS=5
AR_MAX_CHAT_ROUNDS=10

# Price check scheduling
AR_CHECK_INTERVAL_HOURS=6.0
AR_INTERVAL_JITTER_PCT=0.3

# Notifications
AR_TELEGRAM_BOT_TOKEN=
AR_TELEGRAM_CHAT_ID=
AR_NTFY_TOPIC=
AR_NTFY_SERVER=https://ntfy.sh
